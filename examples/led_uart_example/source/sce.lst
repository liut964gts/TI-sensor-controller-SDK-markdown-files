               .segment begin "Task: LED Blinker"
               ledBlinker/initialize:
               ;? // Drive the LED pin low (LED off) on the LaunchPad
               ;? gpioClearOutput(AUXIO_O_LED);
0143 ---- 54bb                         iobclr      #(12 & 0x7), [#(IOP_AIODIO0_GPIODOUT + (12 >> 3))]
               ;?
               ;? // Schedule the first toggle
               ;? fwScheduleTask(BLINK_INTERVAL);
0144 ---- 0010                         ld          R0, #16
0145 ---- 0c9e                         st          R0, [#(pFwTaskExecuteScheduleTable + 0)]
               ledBlinker/initializeDone:
0146 ---- adb7                         rts




               ledBlinker/execute:
               ;? // Set or clear the LED
               ;? if (state.counter & 0x01) {
0147 ---- 08b3                         ld          R0, [#ledBlinker/state/counter]
0148 ---- 8c01                         tst         R0, #1
0149 ---- b602                         bz          /id0037
               ;?     gpioSetOutput(AUXIO_O_LED);
014a ---- 74bb                             iobset      #(12 & 0x7), [#(IOP_AIODIO0_GPIODOUT + (12 >> 3))]
               ;? } else {
014b ---- 054d                         jmp         /id0039
               /id0037:
               ;?     gpioClearOutput(AUXIO_O_LED);
014c ---- 54bb                             iobclr      #(12 & 0x7), [#(IOP_AIODIO0_GPIODOUT + (12 >> 3))]
               ;? }
               /id0039:
               ;?
               ;? // Increment the state counter
               ;? state.counter += 1;
014d ---- 08b3                         ld          R0, [#ledBlinker/state/counter]
014e ---- 8801                         add         R0, #1
014f ---- 0cb3                         st          R0, [#ledBlinker/state/counter]
               ;?
               ;? // Notify the MCU periodically
               ;? ifnot (state.counter & 0x000F) {
0150 ---- 08b3                         ld          R0, [#ledBlinker/state/counter]
0151 ---- 8c0f                         tst         R0, #15
0152 ---- be06                         bnz         /id0042
               ;?     output.counter = state.counter >> 4;
0153 ---- 08b3                             ld          R0, [#ledBlinker/state/counter]
0154 ---- 8dac                             lsr         R0, #4
0155 ---- 0cb2                             st          R0, [#ledBlinker/output/counter]
               ;?     fwGenAlertInterrupt();
0156 ---- 08a8                             ld          R0, [#fwCtrlInt/bvTaskIoAlert]
0157 ---- 8201                             or          R0, #(1 << 0)
0158 ---- 0ca8                             st          R0, [#fwCtrlInt/bvTaskIoAlert]
               ;? }
               /id0042:
               ;?
               ;? // Schedule the next execution
               ;? fwScheduleTask(1);
0159 ---- 0001                         ld          R0, #1
015a ---- 0c9e                         st          R0, [#(pFwTaskExecuteScheduleTable + 0)]
               ledBlinker/executeDone:
015b ---- adb7                         rts




               ledBlinker/terminate:
               ;? // Leave the LED off on shutdown
               ;? gpioClearOutput(AUXIO_O_LED);
015c ---- 54bb                         iobclr      #(12 & 0x7), [#(IOP_AIODIO0_GPIODOUT + (12 >> 3))]
               ledBlinker/terminateDone:
015d ---- adb7                         rts
               .segment end "Task: LED Blinker"
               .segment begin "Task: UART Emulator"
               uartEmulator/initialize:
               ;?
               uartEmulator/initializeDone:
015e ---- adb7                         rts




               uartEmulator/execute:
               ;? // Run the UART emulator until the application sets state.exit
               ;? uartEmulator();
015f ---- 1562                         jsr         UartEmulator
               uartEmulator/executeDone:
0160 ---- adb7                         rts




               uartEmulator/terminate:
               ;?
               uartEmulator/terminateDone:
0161 ---- adb7                         rts
               .segment end "Task: UART Emulator"


               .segment begin "Procedure Library"
               ; TIMER0 event rate = 4 times the UART baud rate
               ;
               ; R7    TX bit counter
               ; R6    TX shift register
               ; R5    RX bit counter / RX new head index / RX timeout counter
               ; R4    RX shift register
               ; R3    RX data storage pointer (last word)
               ; R2    RX idle counter
               ; R1    Temporary variables
               ; R0    Temporary variables (special functionality)


               ; Flags set for each RX byte
               .define BV_UART_RX_TIMEOUT                      0x0800
               .define BV_UART_RX_OVERFLOW                     0x0400
               .define BV_UART_RX_BREAK                        0x0200
               .define BV_UART_RX_FRAMING_ERROR                0x0100

               ; Alert-generating events
               .define BV_UART_ALERT_RX_FIFO_ABOVE_THR         0x0001
               .define BV_UART_ALERT_RX_BYTE_TIMEOUT           0x0002
               .define BV_UART_ALERT_RX_BREAK_OR_FRAMING_ERROR 0x0004
               .define BV_UART_ALERT_TX_FIFO_BELOW_THR         0x0008



               UartEmulator:
                                       ; Disable RX idle timeout
0162 ---- 5000                         ld          R5, #0

                                       ; Set the default number of required idle half-bits before enabling RX
0163 ---- 28b8                         ld          R2, [#uartTaskName/cfg/rxEnableReqIdleCount]

                                       ; Initialize state machine (function pointers)
0164 ---- 017d                         ld          R0, #UartEmulator/txIdle
0165 ---- 0e80                         st          R0, [#uartTxFptr]
0166 ---- 01a7                         ld          R0, #UartEmulator/rxIdle
0167 ---- 0e81                         st          R0, [#uartRxFptr]
0168 8602 0218                         ld          R0, #UartEmulator/sysCmd
016a ---- 0e82                         st          R0, [#uartSysFptr]
016b 8602 0269                         ld          R0, #UartEmulator/txCheckRxStartDisabled
016d ---- 0e83                         st          R0, [#uartTxCheckRxStartFptr]
016e 8602 0274                         ld          R0, #UartEmulator/sysCheckRxStartDisabled
0170 ---- 0e84                         st          R0, [#uartSysCheckRxStartFptr]




               /mainLoop:
                                       ; 0: RX (oversampling)
0171 ---- 0a81                         ld          R0, [#uartRxFptr]
0172 ---- cdb1                         wev1        #WEVSEL_TIMER0
0173 ---- 9db7                         jsr         R0

                                       ; 1: TX
0174 ---- 0a83                         ld          R0, [#uartTxCheckRxStartFptr]
0175 ---- cdb1                         wev1        #WEVSEL_TIMER0
0176 ---- 9db7                         jsr         R0

                                       ; 2: RX (oversampling)
0177 ---- 0a81                         ld          R0, [#uartRxFptr]
0178 ---- cdb1                         wev1        #WEVSEL_TIMER0
0179 ---- 9db7                         jsr         R0

                                       ; 3: System (jumps to the start of the main loop or returns)
017a ---- 0a84                         ld          R0, [#uartSysCheckRxStartFptr]
017b ---- cdb1                         wev1        #WEVSEL_TIMER0
017c ---- 8db7                         jmp         R0






               ;; TX IDLE
               /txIdle:
                                       ; Start transmission of a new byte?
017d ---- 6941                         ld          R6, [#uartTaskName/state/txHead]
017e ---- 1942                         ld          R1, [#uartTaskName/state/txTail]
017f ---- 9d2e                         cmp         R1, R6
0180 ---- b605                         beq         /txIdleNoStart
               /txIdleCheckStartDelay:
                                           ; Load the data byte (LSB) and delay (MSB) into the shift register
0181 8600 98b9                             add         R1, #uartTaskName/input/pTxBuffer
0183 ---- ef09                             ld          R6, [R1]

                                           ; Proceed to "txStartBit" next
0184 ---- 1187                             ld          R1, #/txStartBit
0185 ---- 1e80                             st          R1, [#uartTxFptr]
               /txIdleNoStart:
                                       ; Done
0186 ---- adb7                         rts




               ;; TX START BIT
               /txStartBit:
                                       ; Delay the transmission? (remaining delay is in MSB of the shift register)
0187 8600 eaff                         cmp         R6, #0x00FF
0189 ---- 9e03                         bleu        /txStartBitNoDelay

                                           ; Decrement the delay
018a 86ff e800                             add         R6, #0xFF00
018c ---- 8e04                         bra         /txStartBitDone

                                       ; Otherwise ...
               /txStartBitNoDelay:
                                           ; Transmit the start bit
018d ---- 57bb                             iobclr      #(AUXIO_UART_TX & 0x7), [#(IOP_AIODIO0_GPIODOUT + (AUXIO_UART_TX >> 3))]

                                           ; Initialize the bit counter used by "txDataBit"
018e ---- 7008                             ld          R7, #8

                                           ; Proceed to "txDataBit" next
018f ---- 1192                             ld          R1, #/txDataBit
0190 ---- 1e80                             st          R1, [#uartTxFptr]
               /txStartBitDone:
                                       ; Done
0191 ---- adb7                         rts




               ;; TX DATA BIT
               /txDataBit:
                                       ; Transmit lsb of the shift register
0192 ---- ec01                         tst         R6, #0x0001
0193 ---- be02                         bnz         /txDataBitOutput1

                                           ; Transmit logical 0
0194 ---- 57bb                             iobclr      #(AUXIO_UART_TX & 0x7), [#(IOP_AIODIO0_GPIODOUT + (AUXIO_UART_TX >> 3))]
0195 ---- 8e01                         bra         /txDataBitOutputDone
               /txDataBitOutput1:
                                           ; Transmit logical 1
0196 ---- 77bb                             iobset      #(AUXIO_UART_TX & 0x7), [#(IOP_AIODIO0_GPIODOUT + (AUXIO_UART_TX >> 3))]
               /txDataBitOutputDone:
                                       ; Update the shift register
0197 ---- eda9                         lsr         R6, #1

                                       ; Proceed to "txStopBit" next when the msb has been transmitted (counter in R7
                                       ; goes from 8 to 0)
0198 ---- f8ff                         add         R7, #-1
0199 ---- be02                         bnz         /txDataBitNotMsb
019a ---- 119d                             ld          R1, #/txStopBit
019b ---- 1e80                             st          R1, [#uartTxFptr]
               /txDataBitNotMsb:
                                       ; Done
019c ---- adb7                         rts




               ;; TX STOP BIT
               /txStopBit:
                                       ; Proceed to "txIdle" next, for a second stop bit
019d ---- 117d                         ld          R1, #/txIdle
019e ---- 1e80                         st          R1, [#uartTxFptr]

                                       ; Transmit the stop bit
019f ---- 77bb                         iobset      #(AUXIO_UART_TX & 0x7), [#(IOP_AIODIO0_GPIODOUT + (AUXIO_UART_TX >> 3))]

                                       ; Move on the TX FIFO tail index, wrapping at UART_TX_BUFFER_SIZE
01a0 ---- 1942                         ld          R1, [#uartTaskName/state/txTail]
01a1 ---- 9801                         add         R1, #1
01a2 ---- 9a40                         cmp         R1, #UART_TX_BUFFER_SIZE
01a3 ---- ae01                         bltu        /txStopBitFifoNoWrap
01a4 ---- 1000                             ld          R1, #0
01a5 ---- 1d42 /txStopBitFifoNoWrap:   st          R1, [#uartTaskName/state/txTail]

                                       ; Done
01a6 ---- adb7                         rts






               /rxIdle:
                                       ; If the RX timeout counter is active ...
01a7 ---- da00                         cmp         R5, #0
01a8 ---- 9e09                         bleu        /rxIdleNoTimeout

                                           ; Decrement it and, and if timeout now ...
01a9 ---- d8ff                             add         R5, #-1
01aa ---- be07                             bnz         /rxIdleNoTimeout

                                               ; Set the TIMEOUT flag for the last received byte
01ab 8608 c200                                 or          R4, #BV_UART_RX_TIMEOUT
01ad ---- cf2b                                 st          R4, [R3]

                                               ; Set the TIMEOUT event for ALERT interrupt generation
01ae ---- 1939                                 ld          R1, [#uartTaskName/state/alertBacklog]
01af ---- 9202                                 or          R1, #BV_UART_ALERT_RX_BYTE_TIMEOUT
01b0 ---- 1d39                                 st          R1, [#uartTaskName/state/alertBacklog]

                                               ; Done
01b1 ---- adb7                                 rts

               /rxIdleNoTimeout:
                                       ; If RX should be enabled ...
01b2 ---- 093d                         ld          R0, [#uartTaskName/state/rxEnable]
01b3 ---- 193e                         ld          R1, [#uartTaskName/state/rxEnabled]
01b4 ---- 8d29                         cmp         R0, R1
01b5 ---- 9e0e                         bleu        /rxIdleNoRxEnable

                                           ; If the required idle period has not yet expired ...
01b6 ---- aa00                             cmp         R2, #0
01b7 ---- b605                             beq         /rxIdleRxEnable

                                               ; Decrement the countdown
01b8 ---- a8ff                                 add         R2, #-1

                                               ; If the RX line is not idle now ...
01b9 ---- 24c0                                 iobtst      #(AUXIO_UART_RX & 0x7), [#(IOP_AIODIO0_GPIODIN + (AUXIO_UART_RX >> 3))]
01ba ---- ae01                                 biob1       /rxIdleRxEnableStillIdle

                                                   ; Reset the countdown
01bb ---- 28b8                                     ld          R2, [#uartTaskName/cfg/rxEnableReqIdleCount]
01bc ---- adb7 /rxIdleRxEnableStillIdle:   rts

                                           ; Otherwise, if the required idle period has expired ...
               /rxIdleRxEnable:
                                               ; Enable start-bit detection
01bd 8602 126c                                 ld          R1, #/txCheckRxStartEnabled
01bf ---- 1e83                                 st          R1, [#uartTxCheckRxStartFptr]
01c0 8602 1277                                 ld          R1, #/sysCheckRxStartEnabled
01c2 ---- 1e84                                 st          R1, [#uartSysCheckRxStartFptr]

                                               ; Indicate that RX is enabled
01c3 ---- 0d3e                                 st          R0, [#uartTaskName/state/rxEnabled]
               /rxIdleNoRxEnable:
                                       ; Done
01c4 ---- adb7                         rts




               /rxDisable:
                                       ; Disable start-bit detection
01c5 8602 0269                         ld          R0, #/txCheckRxStartDisabled
01c7 ---- 0e83                         st          R0, [#uartTxCheckRxStartFptr]
01c8 8602 0274                         ld          R0, #/sysCheckRxStartDisabled
01ca ---- 0e84                         st          R0, [#uartSysCheckRxStartFptr]

                                       ; Do "rxIdle" next
01cb ---- 01a7                         ld          R0, #/rxIdle
01cc ---- 0e81                         st          R0, [#uartRxFptr]

                                       ; Disable the RX timeout
01cd ---- 5000                         ld          R5, #0

                                       ; Indicate that RX is disabled
01ce ---- 5d3e                         st          R5, [#uartTaskName/state/rxEnabled]

                                       ; Reset the required number of idle periods before allowing RX to be enabled
01cf ---- 28b8                         ld          R2, [#uartTaskName/cfg/rxEnableReqIdleCount]

                                       ; Done
01d0 ---- adb7                         rts




               /rxStartBit:
                                       ; Stop start bit detection
01d1 8602 1269                         ld          R1, #/txCheckRxStartDisabled
01d3 ---- 1e83                         st          R1, [#uartTxCheckRxStartFptr]
01d4 8602 1274                         ld          R1, #/sysCheckRxStartDisabled
01d6 ---- 1e84                         st          R1, [#uartSysCheckRxStartFptr]

                                       ; Initialize the bit counter used by "rxDataBit"
01d7 ---- 5008                         ld          R5, #8

                                       ; Clear the shift register
01d8 ---- 4000                         ld          R4, #0x0000

                                       ; Fetch the pointer to RX head
01d9 ---- 393f                         ld          R3, [#uartTaskName/state/rxHead]
01da 8600 b8f9                         add         R3, #uartTaskName/output/pRxBuffer

                                       ; Proceed to "preRxDataBit" next
01dc ---- 11df                         ld          R1, #/preRxDataBit
01dd ---- 1e81                         st          R1, [#uartRxFptr]

                                       ; Done
01de ---- adb7                         rts




               /preRxDataBit:
                                       ; Update the shift register
01df ---- cda9                         lsr         R4, #1

                                       ; Proceed to "rxDataBit" next
01e0 ---- 11e3                         ld          R1, #/rxDataBit
01e1 ---- 1e81                         st          R1, [#uartRxFptr]

                                       ; Done
01e2 ---- adb7                         rts




               /rxDataBit:
                                       ; Shift in a 0 or a 1 into the shift register
01e3 ---- fd47                         nop
01e4 ---- 24c0                         iobtst      #(AUXIO_UART_RX & 0x7), [#(IOP_AIODIO0_GPIODIN + (AUXIO_UART_RX >> 3))]
01e5 ---- a601                         biob0       /rxDataBitZero
01e6 ---- c280                             or          R4, #0x0080
               /rxDataBitZero:
                                       ; If msb has been received, proceed to "preRxStopBit" next, otherwise "preRxDataBit"
01e7 ---- d8ff                         add         R5, #-1
01e8 ---- be02                         bnz         /rxDataBitNotDone
01e9 ---- 11ee                             ld          R1, #/preRxStopBit
01ea ---- 8e01                         bra         /rxDataBitDone
01eb ---- 11df /rxDataBitNotDone:          ld          R1, #/preRxDataBit
01ec ---- 1e81 /rxDataBitDone:         st          R1, [#uartRxFptr]

                                       ; Done
01ed ---- adb7                         rts




               /preRxStopBit:
                                       ; Calculate the new RX FIFO head index, wrapping at UART_RX_BUFFER_SIZE
01ee ---- 593f                         ld          R5, [#uartTaskName/state/rxHead]
01ef ---- d801                         add         R5, #1
01f0 ---- da40                         cmp         R5, #UART_RX_BUFFER_SIZE
01f1 ---- ae01                         bltu        /rxStopBitFifoNoWrap
01f2 ---- 5000                             ld          R5, #0
               /rxStopBitFifoNoWrap:
                                       ; Proceed to "rxStopBit" next
01f3 ---- 01f6                         ld          R0, #/rxStopBit
01f4 ---- 0e81                         st          R0, [#uartRxFptr]

                                       ; Done
01f5 ---- adb7                         rts




               /rxStopBit:
                                       ; If not a valid stop bit ...
01f6 ---- fd47                         nop
01f7 ---- 24c0                         iobtst      #(AUXIO_UART_RX & 0x7), [#(IOP_AIODIO0_GPIODIN + (AUXIO_UART_RX >> 3))]
01f8 ---- ae0b                         biob1       /rxStopBitValid

                                           ; Depending on the received byte ...
01f9 ---- ccff                             tst         R4, #0xFF
01fa ---- be03                             bnz         /rxStopBitFramingError
               /rxStopBitBreak:
                                               ; If 0x00, indicate "break"
01fb 8602 c200                                 or          R4, #BV_UART_RX_BREAK
01fd ---- 8e02                             bra         /rxStopBitNotFramingError
               /rxStopBitFramingError:
                                               ; Otherwise, indicate framing error
01fe 8601 c200                                 or          R4, #BV_UART_RX_FRAMING_ERROR
               /rxStopBitNotFramingError:

                                           ; Set the BREAK OR FRAMING ERROR event for ALERT interrupt generation
0200 ---- 1939                             ld          R1, [#uartTaskName/state/alertBacklog]
0201 ---- 9204                             or          R1, #BV_UART_ALERT_RX_BREAK_OR_FRAMING_ERROR
0202 ---- 1d39                             st          R1, [#uartTaskName/state/alertBacklog]

                                           ; Bail out and come back later
0203 ---- adb7                             rts
               /rxStopBitValid:
                                       ; Proceed to "rxIdle" next
0204 ---- 01a7                         ld          R0, #/rxIdle
0205 ---- 0e81                         st          R0, [#uartRxFptr]

                                       ; Re-enable start-bit detection
0206 8602 026c                         ld          R0, #/txCheckRxStartEnabled
0208 ---- 0e83                         st          R0, [#uartTxCheckRxStartFptr]
0209 8602 0277                         ld          R0, #/sysCheckRxStartEnabled
020b ---- 0e84                         st          R0, [#uartSysCheckRxStartFptr]

                                       ; If the updated head index equals the tail index ...
020c ---- 0940                         ld          R0, [#uartTaskName/state/rxTail]
020d ---- dd28                         cmp         R5, R0
020e ---- be05                         bneq        /rxStopBitNotOverflow

                                           ; Indicate overflow
020f 8604 c200                             or          R4, #BV_UART_RX_OVERFLOW

                                           ; Store the received byte
0211 ---- cf2b                             st          R4, [R3]

                                           ; Initialize the timeout counter, which will be used shortly in "rxIdle"
0212 ---- 58b7                             ld          R5, [#uartTaskName/cfg/rxByteTimeout]

                                           ; Bail out without updating the head index
0213 ---- adb7                             rts
               /rxStopBitNotOverflow:
                                       ; Store the received byte
0214 ---- cf2b                         st          R4, [R3]

                                       ; Update the RX head index
0215 ---- 5d3f                         st          R5, [#uartTaskName/state/rxHead]

                                       ; Initialize the timeout counter, which will be used shortly in "rxIdle"
0216 ---- 58b7                         ld          R5, [#uartTaskName/cfg/rxByteTimeout]

                                       ; Done
0217 ---- adb7                         rts






               /sysCmd:
                                       ; Exit the UART emulator?
0218 ---- 193c                         ld          R1, [#uartTaskName/state/exit]
0219 ---- 9a00                         cmp         R1, #0
021a ---- b601                         beq         /sysCmdNoExit
021b ---- adb7                             rts
               /sysCmdNoExit:
               /sysCmdRxDisable:
                                       ; Disable RX?
021c ---- 093d                         ld          R0, [#uartTaskName/state/rxEnable]
021d ---- 193e                         ld          R1, [#uartTaskName/state/rxEnabled]
021e ---- 8d29                         cmp         R0, R1
021f ---- a602                         bgeu        /sysCmdNoRxDisable

                                           ; Do "rxDisable" in the next upcoming RX state
0220 ---- 01c5                             ld          R0, #/rxDisable
0221 ---- 0e81                             st          R0, [#uartRxFptr]
               /sysCmdNoRxDisable:
                                       ; Do ALERT mask update next
0222 8602 0226                         ld          R0, #/sysAlertMaskUpdate
0224 ---- 0e82                         st          R0, [#uartSysFptr]

                                       ; Keep on executing from the start of the main loop
0225 ---- 0571                         jmp         /mainLoop




               /sysAlertMaskUpdate:
                                       ; Update the ALERT mask
0226 ---- 08b4                         ld          R0, [#uartTaskName/cfg/alertMask]
0227 ---- 0d3b                         st          R0, [#uartTaskName/state/alertMask]

                                       ; Clear FIFO flags and currently disabled events from the backlog
0228 ---- 1939                         ld          R1, [#uartTaskName/state/alertBacklog]
0229 ---- 9d00                         and         R1, R0
022a ---- 9006                         and         R1, #((~(BV_UART_ALERT_RX_FIFO_ABOVE_THR | BV_UART_ALERT_TX_FIFO_BELOW_THR)) & 0xF)
022b ---- 1d39                         st          R1, [#uartTaskName/state/alertBacklog]

                                       ; Do RX FIFO event generation next
022c 8602 0230                         ld          R0, #/sysAlertCheckRxFifo0
022e ---- 0e82                         st          R0, [#uartSysFptr]

                                       ; Keep on executing from the start of the main loop
022f ---- 0571                         jmp         /mainLoop




               /sysAlertCheckRxFifo0:
                                       ; Calculate the number of bytes currently in the RX FIFO
0230 ---- 093f                         ld          R0, [#uartTaskName/state/rxHead]
0231 ---- 1940                         ld          R1, [#uartTaskName/state/rxTail]
0232 ---- 8d19                         sub         R0, R1
0233 ---- d601                         bpos        /sysAlertsRxCountNoWrap
0234 ---- 8840                             add         R0, #UART_RX_BUFFER_SIZE
               /sysAlertsRxCountNoWrap:
                                       ; There is not sufficient time to compare the FIFO count with the threshold and
                                       ; set flags, so we store the count temporarily in RAM
0235 ---- 0e7f                         st          R0, [#uartRxTxFifoCount]

                                       ; Continue RX FIFO event generation next
0236 8602 023a                         ld          R0, #/sysAlertCheckRxFifo1
0238 ---- 0e82                         st          R0, [#uartSysFptr]

                                       ; Keep on executing from the start of the main loop
0239 ---- 0571                         jmp         /mainLoop




               /sysAlertCheckRxFifo1:
                                       ; If the RX FIFO is at or above the specified threshold ...
023a ---- 0a7f                         ld          R0, [#uartRxTxFifoCount]
023b ---- 18b5                         ld          R1, [#uartTaskName/cfg/alertRxFifoThr]
023c ---- 8d29                         cmp         R0, R1
023d ---- ae03                         bltu        /sysAlertsRxCountNoEvent

                                           ; Generate RX FIFO ABOVE THR event
023e ---- 0939                            ld          R0, [#uartTaskName/state/alertBacklog]
023f ---- 8201                            or          R0, #BV_UART_ALERT_RX_FIFO_ABOVE_THR
0240 ---- 0d39                            st          R0, [#uartTaskName/state/alertBacklog]
               /sysAlertsRxCountNoEvent:
                                       ; Do TX FIFO event generation next
0241 8602 0245                         ld          R0, #/sysAlertCheckTxFifo0
0243 ---- 0e82                         st          R0, [#uartSysFptr]

                                       ; Keep on executing from the start of the main loop
0244 ---- 0571                         jmp         /mainLoop




               /sysAlertCheckTxFifo0:
                                       ; Calculate the number of bytes currently in the TX FIFO
0245 ---- 0941                         ld          R0, [#uartTaskName/state/txHead]
0246 ---- 1942                         ld          R1, [#uartTaskName/state/txTail]
0247 ---- 8d19                         sub         R0, R1
0248 ---- d601                         bpos        /sysAlertsTxCountNoWrap
0249 ---- 8840                             add         R0, #UART_TX_BUFFER_SIZE
               /sysAlertsTxCountNoWrap:
                                       ; There is not sufficient time to compare the FIFO count with the threshold and
                                       ; set flags, so we store the count temporarily in RAM
024a ---- 0e7f                         st          R0, [#uartRxTxFifoCount]

                                       ; Continue TX FIFO event generation next
024b 8602 024f                         ld          R0, #/sysAlertCheckTxFifo1
024d ---- 0e82                         st          R0, [#uartSysFptr]

                                       ; Keep on executing from the start of the main loop
024e ---- 0571                         jmp         /mainLoop




               /sysAlertCheckTxFifo1:
                                       ; If the TX FIFO is at or below the specified threshold ...
024f ---- 0a7f                         ld          R0, [#uartRxTxFifoCount]
0250 ---- 18b6                         ld          R1, [#uartTaskName/cfg/alertTxFifoThr]
0251 ---- 8d29                         cmp         R0, R1
0252 ---- 9603                         bgtu        /sysAlertsTxCountNoEvent

                                           ; Generate TX FIFO BELOW THR event
0253 ---- 0939                             ld          R0, [#uartTaskName/state/alertBacklog]
0254 ---- 8208                             or          R0, #BV_UART_ALERT_TX_FIFO_BELOW_THR
0255 ---- 0d39                             st          R0, [#uartTaskName/state/alertBacklog]
               /sysAlertsTxCountNoEvent:
                                       ; Do ALERT interrupt generation next
0256 8602 025a                         ld          R0, #/sysAlertGen
0258 ---- 0e82                         st          R0, [#uartSysFptr]

                                       ; Keep on executing from the start of the main loop
0259 ---- 0571                         jmp         /mainLoop




               /sysAlertGen:
                                       ; If the previous events have been handled by the application ...
025a ---- 093a                         ld          R0, [#uartTaskName/state/alertEvents]
025b ---- 8a00                         cmp         R0, #0x0000
025c ---- be08                         bneq        /sysAlertsNoGen

                                           ; Mask out the disabled events from the backlog
025d ---- 0939                             ld          R0, [#uartTaskName/state/alertBacklog]
025e ---- 193b                             ld          R1, [#uartTaskName/state/alertMask]
025f ---- 8d01                             and         R0, R1

                                           ; If there are any enabled events in the backlog ...
0260 ---- b604                             bz          /sysAlertsNoGen

                                               ; Generate alert interrupt
0261 ---- 0d3a                                 st          R0, [#uartTaskName/state/alertEvents]
0262 ---- 6540                                 iobset      #IOB_EVCTL_SWEV_ALERT, [#IOP_EVCTL_SWEVSET]

                                               ; Clear the backlog
0263 ---- 0000                                 ld          R0, #0x0000
0264 ---- 0d39                                 st          R0, [#uartTaskName/state/alertBacklog]
               /sysAlertsNoGen:
                                       ; Do system commands next
0265 8602 0218                         ld          R0, #/sysCmd
0267 ---- 0e82                         st          R0, [#uartSysFptr]

